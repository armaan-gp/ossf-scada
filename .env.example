# Copy this file to `.env` and fill in real values.
# Do not commit your real `.env` to source control.

# PostgreSQL connection string
DATABASE_URL="postgresql://username:password@host:5432/database?sslmode=require"

# Session signing secret (example command: `openssl rand -base64 32`)
SESSION_SECRET="replace-with-random-secret"

# Arduino IoT API credentials
ARDUINO_API_CLIENT_ID="replace-with-arduino-client-id"
ARDUINO_API_CLIENT_SECRET="replace-with-arduino-client-secret"

# Optional: bearer token required by cron endpoints when set
CRON_SECRET="replace-with-cron-secret"

# Encryption key for stored Gmail App Password (recommended)
ALERT_EMAIL_ENCRYPTION_KEY="replace-with-encryption-key"

# Optional fallback encryption key if ALERT_EMAIL_ENCRYPTION_KEY is not set
ENCRYPTION_KEY="replace-with-fallback-encryption-key"
