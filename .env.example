# Copy this file to `.env.local` and fill in real values.
# Do not commit your real `.env.local` to source control.

# Required: PostgreSQL connection string (used by app + drizzle push)
DATABASE_URL="postgresql://username:password@host:5432/database?sslmode=require"

# Required: session signing secret (example command: `openssl rand -base64 32`)
SESSION_SECRET="replace-with-random-secret"

# Recommended: public app URL used when generating invite links (client-visible)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional server-only fallback URL for invite links when NEXT_PUBLIC_APP_URL is not set
APP_URL="http://localhost:3000"

# Required: Arduino IoT API credentials
ARDUINO_API_CLIENT_ID="replace-with-arduino-client-id"
ARDUINO_API_CLIENT_SECRET="replace-with-arduino-client-secret"

# Recommended: bearer token required by cron endpoints when set
CRON_SECRET="replace-with-cron-secret"

# Recommended: primary encryption key for stored Gmail App Password.
# Keep this stable per environment.
ALERT_EMAIL_ENCRYPTION_KEY="replace-with-encryption-key"

# Optional fallback key if ALERT_EMAIL_ENCRYPTION_KEY is not set.
# Prefer setting ALERT_EMAIL_ENCRYPTION_KEY and leaving this as a backup.
ENCRYPTION_KEY="replace-with-fallback-encryption-key"

# Note: Do not add ephemeral Vercel-injected tokens (for example VERCEL_OIDC_TOKEN) here.
